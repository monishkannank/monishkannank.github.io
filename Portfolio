/* ============================================================
   MONISH KANNAN K — CORPORATE ACTIONS PORTFOLIO
   Design language: engraved bond-certificate meets settlement ledger.
   ============================================================ */

:root{
  --ink-900:#0A1220;
  --ink-850:#0D1729;
  --ink-800:#101E33;
  --ink-700:#182B45;
  --brass:#C9A227;
  --brass-soft:#E4C766;
  --brass-dim:#8A7228;
  --teal:#54B3A6;
  --teal-dim:#356E67;
  --claret:#8C3B36;
  --text-hi:#F3F1E6;
  --text-mid:#AEB8CA;
  --text-dim:#71809A;
  --rule:rgba(243,241,230,0.12);
  --rule-strong:rgba(243,241,230,0.26);
  --serif:'Fraunces', serif;
  --sans:'Inter', sans-serif;
  --mono:'IBM Plex Mono', monospace;
}
*{box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{
  margin:0;
  background:var(--ink-900);
  color:var(--text-hi);
  font-family:var(--sans);
  line-height:1.5;
  -webkit-font-smoothing:antialiased;
  position:relative;
}
::selection{background:var(--brass);color:var(--ink-900);}
a{color:inherit;text-decoration:none;}
.wrap{max-width:1080px;margin:0 auto;padding:0 32px;}
@media (max-width:640px){.wrap{padding:0 20px;}}

/* faint engraved guilloché field across the whole page */
body::before{
  content:"";position:fixed;inset:0;pointer-events:none;z-index:0;opacity:.05;
  background-image:
    repeating-radial-gradient(circle at 0% 0%, transparent 0, transparent 26px, var(--brass-soft) 27px, transparent 28px),
    repeating-radial-gradient(circle at 100% 100%, transparent 0, transparent 34px, var(--teal) 35px, transparent 36px);
  background-size:220px 220px, 260px 260px;
}

/* ---------------- reveal ---------------- */
.reveal{opacity:0;transform:translateY(14px);transition:opacity .7s ease, transform .7s ease;}
.reveal.in{opacity:1;transform:translateY(0);}
@media (prefers-reduced-motion: reduce){
  .reveal{opacity:1;transform:none;transition:none;}
  html{scroll-behavior:auto;}
}

/* ---------------- rosette monogram ---------------- */
.rosette{width:40px;height:40px;flex:none;}
.rosette circle{fill:none;stroke:var(--brass-soft);}
.rosette text{font-family:var(--serif);font-size:13px;fill:var(--brass-soft);font-weight:600;}

/* ---------------- notice bar ---------------- */
.noticebar{border-bottom:1px solid var(--rule);font-family:var(--mono);font-size:10.5px;letter-spacing:.08em;text-transform:uppercase;color:var(--text-dim);position:relative;z-index:2;}
.noticebar .wrap{display:flex;justify-content:space-between;align-items:center;padding:14px 32px;flex-wrap:wrap;gap:8px;}
.noticebar .ref{color:var(--brass-soft);}

/* ---------------- nav ---------------- */
nav.topnav{
  position:sticky;top:0;z-index:50;
  background:rgba(10,18,32,.86);backdrop-filter:blur(10px);
  border-bottom:1px solid var(--rule);
}
nav.topnav .wrap{display:flex;align-items:center;justify-content:space-between;padding:14px 32px;gap:20px;}
.brand{display:flex;align-items:center;gap:12px;font-family:var(--serif);font-size:16px;font-weight:560;letter-spacing:.01em;}
.navlinks{display:flex;gap:2px;font-family:var(--mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;}
.navlinks a{
  padding:8px 14px;color:var(--text-dim);border-bottom:2px solid transparent;transition:color .2s, border-color .2s;
  display:flex;align-items:center;gap:7px;
}
.navlinks a .fk{color:var(--brass-dim);font-size:10px;}
.navlinks a:hover{color:var(--text-hi);}
.navlinks a.active{color:var(--brass-soft);border-color:var(--brass-soft);}
.navlinks a.active .fk{color:var(--brass-soft);}
@media (max-width:700px){
  nav.topnav .wrap{flex-direction:column;align-items:flex-start;gap:10px;padding:14px 20px;}
  .navlinks{flex-wrap:wrap;gap:0;}
}

/* ---------------- page header block ---------------- */
.pagehead{padding:56px 0 40px;position:relative;z-index:2;}
.pagehead .eyebrow{font-family:var(--mono);font-size:11.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--teal);margin-bottom:16px;display:flex;align-items:center;gap:10px;}
.pagehead .eyebrow::before{content:"";width:22px;height:1px;background:var(--teal);display:inline-block;}
.pagehead h1{font-family:var(--serif);font-weight:560;font-size:clamp(32px,5.4vw,54px);line-height:1.04;margin:0 0 14px;letter-spacing:-.01em;}
.pagehead .sub{font-size:15.5px;color:var(--text-mid);max-width:640px;line-height:1.7;margin:0;}

/* ---------------- generic section ---------------- */
section{padding:56px 0;border-top:1px solid var(--rule);position:relative;z-index:2;}
.sec-head{display:flex;align-items:baseline;justify-content:space-between;gap:20px;margin-bottom:34px;flex-wrap:wrap;}
.sec-title{font-family:var(--serif);font-size:clamp(22px,3.2vw,30px);font-weight:560;margin:0;letter-spacing:-.01em;}
.sec-tag{font-family:var(--mono);font-size:11px;color:var(--text-dim);letter-spacing:.1em;text-transform:uppercase;}

/* ---------------- stat strip ---------------- */
.statrow{display:flex;gap:0;flex-wrap:wrap;border-top:1px solid var(--rule-strong);}
.stat{flex:1 1 150px;padding:20px 22px 18px 0;border-right:1px solid var(--rule);}
.stat:last-child{border-right:none;}
.stat .num{font-family:var(--mono);font-size:24px;color:var(--brass-soft);font-weight:600;letter-spacing:-.02em;}
.stat .lbl{font-size:11.5px;color:var(--text-dim);margin-top:4px;letter-spacing:.02em;}

/* ---------------- case cards (index -> subpages) ---------------- */
.casegrid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--rule);border:1px solid var(--rule);}
@media (max-width:820px){.casegrid{grid-template-columns:1fr;}}
.case{background:var(--ink-900);padding:30px 26px;transition:background .25s;}
.case:hover{background:var(--ink-850);}
.case .fk{font-family:var(--mono);font-size:11px;color:var(--brass-dim);letter-spacing:.1em;margin-bottom:16px;display:block;}
.case h3{font-family:var(--serif);font-size:21px;margin:0 0 10px;font-weight:560;}
.case p{font-size:13.5px;color:var(--text-mid);line-height:1.65;margin:0 0 18px;}
.case .go{font-family:var(--mono);font-size:11px;color:var(--teal);letter-spacing:.06em;text-transform:uppercase;}
.case:hover .go{color:var(--brass-soft);}

/* ---------------- lifecycle timeline ---------------- */
.lifecycle{position:relative;padding-top:6px;}
.lifecycle-track{position:relative;display:flex;justify-content:space-between;padding-bottom:6px;}
.lifecycle-track::before{content:"";position:absolute;left:0;right:0;top:7px;height:1px;background:linear-gradient(90deg, var(--rule-strong), var(--teal) 15%, var(--brass) 55%, var(--brass-soft) 85%, var(--teal));opacity:.55;}
.lc-node{position:relative;flex:1;padding-right:18px;min-width:150px;margin-bottom:26px;}
.lc-node:last-child{padding-right:0;}
.lc-dot{width:15px;height:15px;border-radius:50%;background:var(--ink-900);border:2px solid var(--brass-soft);position:relative;z-index:2;margin-bottom:14px;}
.lc-node.current .lc-dot{background:var(--teal);border-color:var(--teal);box-shadow:0 0 0 4px rgba(84,179,166,.18);}
.lc-date{font-family:var(--mono);font-size:11px;color:var(--text-dim);letter-spacing:.04em;margin-bottom:6px;}
.lc-label{font-family:var(--serif);font-size:16.5px;font-weight:560;margin-bottom:6px;}
.lc-desc{font-size:12.5px;color:var(--text-mid);line-height:1.55;}
@media (max-width:760px){
  .lifecycle-track{flex-direction:column;gap:0;}
  .lifecycle-track::before{left:7px;top:0;bottom:0;width:1px;height:auto;right:auto;background:linear-gradient(180deg, var(--rule-strong), var(--teal) 15%, var(--brass) 55%, var(--brass-soft) 85%, var(--teal));}
  .lc-node{padding-right:0;padding-left:30px;margin-bottom:30px;}
  .lc-dot{position:absolute;left:0;top:2px;margin-bottom:0;}
}

/* ---------------- notice cards ---------------- */
.notice{border:1px solid var(--rule-strong);background:linear-gradient(180deg, rgba(243,241,230,.03), transparent 40%);margin-bottom:28px;position:relative;}
.notice::before{content:"";position:absolute;top:10px;left:10px;right:10px;bottom:10px;border:1px solid var(--rule);pointer-events:none;}
.notice-head{display:flex;justify-content:space-between;align-items:flex-start;gap:16px;flex-wrap:wrap;padding:24px 28px 18px;border-bottom:1px solid var(--rule);}
.notice-role{font-family:var(--serif);font-size:21px;font-weight:560;margin:0 0 4px;}
.notice-org{font-size:13px;color:var(--text-mid);}
.notice-meta{text-align:right;font-family:var(--mono);font-size:11px;color:var(--text-dim);line-height:1.8;}
.status-pill{display:inline-block;font-family:var(--mono);font-size:10.5px;letter-spacing:.08em;text-transform:uppercase;padding:3px 10px;border:1px solid var(--teal);color:var(--teal);margin-left:8px;}
.status-pill.settled{border-color:var(--brass-soft);color:var(--brass-soft);}
.notice-body{padding:22px 28px 26px;}
.notice ul{margin:0;padding:0;list-style:none;}
.notice li{position:relative;padding-left:20px;margin-bottom:12px;font-size:14px;color:var(--text-mid);line-height:1.6;}
.notice li:last-child{margin-bottom:0;}
.notice li::before{content:"—";position:absolute;left:0;color:var(--brass);}
.notice li strong{color:var(--text-hi);font-weight:600;}
.codes{display:flex;flex-wrap:wrap;gap:7px;margin-top:18px;}
.code{font-family:var(--mono);font-size:11px;padding:3px 8px;border:1px solid var(--rule-strong);color:var(--text-mid);letter-spacing:.03em;cursor:default;position:relative;}
.code:hover{border-color:var(--brass-soft);color:var(--brass-soft);}

/* ---------------- coverage grid ---------------- */
.coverage-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1px;background:var(--rule);border:1px solid var(--rule);}
.cov-cell{background:var(--ink-900);padding:22px 24px;}
.cov-cell h4{font-family:var(--mono);font-size:11px;letter-spacing:.09em;text-transform:uppercase;color:var(--teal);margin:0 0 12px;}
.cov-cell p{margin:0;font-size:13.5px;color:var(--text-mid);line-height:1.7;}

/* ---------------- ticker ---------------- */
.ticker-shell{border-top:1px solid var(--rule);border-bottom:1px solid var(--rule);overflow:hidden;padding:16px 0;position:relative;z-index:2;}
.ticker-track{display:flex;gap:28px;white-space:nowrap;width:max-content;animation:scroll-left 46s linear infinite;}
.ticker-shell:hover .ticker-track{animation-play-state:paused;}
@keyframes scroll-left{from{transform:translateX(0);}to{transform:translateX(-50%);}}
.tick{font-family:var(--mono);font-size:12.5px;color:var(--text-dim);letter-spacing:.05em;}
.tick b{color:var(--brass-soft);font-weight:600;}
@media (prefers-reduced-motion: reduce){.ticker-track{animation:none;flex-wrap:wrap;white-space:normal;width:auto;}}

/* ---------------- ledger table ---------------- */
.ledger{width:100%;border-collapse:collapse;font-size:13.5px;}
.ledger tr{border-bottom:1px solid var(--rule);}
.ledger tr:last-child{border-bottom:none;}
.ledger td{padding:16px 10px;vertical-align:top;}
.ledger td:first-child{width:210px;font-family:var(--mono);font-size:11px;letter-spacing:.06em;text-transform:uppercase;color:var(--brass-soft);padding-left:0;}
.ledger td:last-child{color:var(--text-mid);padding-right:0;}
@media (max-width:640px){
  .ledger td{display:block;width:100%!important;padding:4px 0;}
  .ledger tr{display:block;padding:14px 0;}
}

/* ---------------- dial / gauge ---------------- */
.dialgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:28px;}
.dial-card{border:1px solid var(--rule-strong);padding:24px;text-align:center;}
.dial{width:140px;height:80px;margin:0 auto 14px;position:relative;}
.dial svg{width:100%;height:100%;}
.dial-val{font-family:var(--mono);font-size:22px;color:var(--brass-soft);font-weight:600;margin-top:-46px;position:relative;}
.dial-label{font-size:12px;color:var(--text-mid);margin-top:8px;}

/* ---------------- progress rail (ISO standards) ---------------- */
.railrow{margin-bottom:22px;}
.railrow:last-child{margin-bottom:0;}
.rail-top{display:flex;justify-content:space-between;font-family:var(--mono);font-size:11.5px;color:var(--text-mid);margin-bottom:8px;}
.rail-top b{color:var(--text-hi);}
.rail{height:6px;background:var(--ink-700);border:1px solid var(--rule-strong);position:relative;overflow:hidden;}
.rail-fill{height:100%;background:var(--brass);}
.rail-fill.teal{background:var(--teal);}
.rail-fill.dashed{background:repeating-linear-gradient(90deg, var(--teal) 0 6px, transparent 6px 11px);}

/* ---------------- glossary grid (extras) ---------------- */
.glossgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:1px;background:var(--rule);border:1px solid var(--rule);}
.gloss-cell{background:var(--ink-900);padding:18px 20px;}
.gloss-code{font-family:var(--mono);font-size:13px;color:var(--brass-soft);letter-spacing:.05em;margin-bottom:5px;}
.gloss-def{font-size:12.5px;color:var(--text-mid);line-height:1.55;}
.gloss-search{width:100%;background:var(--ink-850);border:1px solid var(--rule-strong);color:var(--text-hi);font-family:var(--mono);font-size:13px;padding:12px 16px;margin-bottom:22px;outline:none;}
.gloss-search:focus{border-color:var(--brass-soft);}
.gloss-search::placeholder{color:var(--text-dim);}
.gloss-cell.hide{display:none;}

/* ---------------- awards ---------------- */
.awards{display:grid;grid-template-columns:1fr 1fr;gap:20px;}
@media (max-width:640px){.awards{grid-template-columns:1fr;}}
.award{border:1px solid var(--brass);padding:26px 24px;position:relative;}
.award::after{content:"";position:absolute;top:6px;left:6px;right:6px;bottom:6px;border:1px solid rgba(201,162,39,.35);pointer-events:none;}
.award .seal{font-family:var(--mono);font-size:10px;letter-spacing:.1em;color:var(--brass-soft);text-transform:uppercase;margin-bottom:10px;}
.award h4{font-family:var(--serif);font-size:18px;margin:0 0 6px;font-weight:560;}
.award p{margin:0;font-size:13px;color:var(--text-mid);}

/* ---------------- education rows ---------------- */
.edu-row{display:flex;justify-content:space-between;gap:20px;flex-wrap:wrap;padding:18px 0;border-bottom:1px solid var(--rule);}
.edu-row:last-child{border-bottom:none;}
.edu-name{font-family:var(--serif);font-size:18px;font-weight:560;}
.edu-sub{font-size:13px;color:var(--text-mid);margin-top:4px;}
.edu-meta{font-family:var(--mono);font-size:12px;color:var(--text-dim);text-align:right;}

/* ---------------- footer ---------------- */
footer{padding:56px 0 60px;position:relative;z-index:2;border-top:1px solid var(--rule);}
.foot-grid{display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:24px;}
.foot-name{font-family:var(--serif);font-size:24px;font-weight:560;}
.foot-links{display:flex;gap:22px;flex-wrap:wrap;font-family:var(--mono);font-size:12.5px;}
.foot-links a{color:var(--text-mid);border-bottom:1px solid transparent;transition:border-color .2s, color .2s;}
.foot-links a:hover{color:var(--brass-soft);border-color:var(--brass-soft);}
.foot-note{font-size:11.5px;color:var(--text-dim);margin-top:30px;font-family:var(--mono);}

